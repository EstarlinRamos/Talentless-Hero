%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: d6fced335fe0e624e8c9d175d9ff6239, type: 3}
  m_Name: Innkeeper_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startNodeIndex: 0
  nodes:
  - editorLabel: Innkeeper - Greeting
    lines:
    - speaker: Innkeeper
      text: Oh! A new face. That's... unexpected.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: We don't get visitors anymore, not since the guards locked down the eastern
        road. And this village isn't exactly on the way to anywhere.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Mountains on three sides, forest to the south, and a blocked road to
        the east. You'd have to be lost or very determined to end up here.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: So which is it? What can I help you with?
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices:
    - choiceText: (I'd like to rest.)
      nextNodeIndex: 1
    - choiceText: (What's going on around here?)
      nextNodeIndex: 2
    - choiceText: (Just looking around.)
      nextNodeIndex: 3
    nextNodeIndex: -1
  - editorLabel: Innkeeper - Rest
    lines:
    - speaker: Innkeeper
      text: Of course, dear. You look like you need it.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: The beds aren't fancy, but they're warm. I'll have something ready for
        you when you wake.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags:
      - rest
    choices: []
    nextNodeIndex: -1
  - editorLabel: Innkeeper - Village Info
    lines:
    - speaker: Innkeeper
      text: Where to begin...
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: "This village has maybe fifteen people on a good day. We've always been
        isolated \u2014 mountains on every side, one road east to the kingdom, and
        the forest to the south."
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: The forest used to be manageable. Loggers and hunters kept things under
        control. But a few weeks ago, more creatures started appearing. Aggressive
        ones.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: "The kingdom sent guards, but instead of checking the forest, they blockaded
        the eastern road. My husband Garrett \u2014 the blacksmith by the entrance
        \u2014 he's furious about it. No merchants, no supplies."
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: "The old man down the road might know more. He's been here a few months
        and spends all day watching the forest from his campfire. Can't miss him
        \u2014 I can see him from this window."
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Anyway, if you need rest, you know where to find me.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices: []
    nextNodeIndex: -1
  - editorLabel: Innkeeper - Casual
    lines:
    - speaker: Innkeeper
      text: Take your time. Not like there's a rush around here.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Though I am curious... you came from up the staircase, didn't you? From
        the mountain path?
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: There's nothing up there but rock and hiking trails. Nobody comes through
        that way.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Well... I suppose you did. Strange times we're living in.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices: []
    nextNodeIndex: -1
