  m_Script: {fileID: 11500000, guid: d6fced335fe0e624e8c9d175d9ff6239, type: 3}
  m_Name: Innkeeper_WraithKilled
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startNodeIndex: 0
  nodes:
  - editorLabel: Innkeeper - Wraith Killed
    lines:
    - speaker: Innkeeper
      text: Something feels different today. Lighter. The forest sounds... normal
        again. Even Garrett is smiling, which is terrifying.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: "Oh, and the strangest thing \u2014 the old man down the road? He's gone.
        Cabin's empty. Just up and vanished."
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: He only showed up a few months ago, now that I think about it. Kept to
        himself. Always watching the forest.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: "...Probably nothing. People come and go. Anyway, whatever you did out
        there \u2014 thank you."
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: The inn's always open for you. No charge. Ever.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices: []
    nextNodeIndex: -1
