  m_Script: {fileID: 11500000, guid: d6fced335fe0e624e8c9d175d9ff6239, type: 3}
  m_Name: InnkeeperRescue_Dialogue
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  startNodeIndex: 0
  nodes:
  - editorLabel: Innkeeper - Rescue
    lines:
    - speaker: Innkeeper
      text: ...Oh good, you're awake.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Found you face-down in the dirt while I was out gathering herbs. You're
        heavier than you look, by the way.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Whatever got you out there did a real number. I patched you up best I
        could.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: You're welcome.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices:
    - choiceText: (Thank you.)
      nextNodeIndex: 1
    - choiceText: (...)
      nextNodeIndex: 2
    nextNodeIndex: -1
  - editorLabel: Rescue - Grateful
    lines:
    - speaker: Innkeeper
      text: Don't mention it. Really.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Just... maybe don't charge head-first into things that can kill you?
        Or at least eat something before you do.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: The inn's here whenever you need it. Try to come back on your own two
        feet next time.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices: []
    nextNodeIndex: -1
  - editorLabel: Rescue - Silent
    lines:
    - speaker: Innkeeper
      text: Not much of a talker even after nearly dying? Stubborn.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: Well, you're healed up. Go on, do whatever it is you do. Just try not
        to make me haul you back again.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Innkeeper
      text: My back isn't what it used to be.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices: []
    nextNodeIndex: -1
