  nodes:
  - editorLabel: Guard C - Blockade
    lines:
    - speaker: Guard
      text: This road is closed by order of the kingdom. Turn around.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: A dangerous creature has been reported in this region. Until the threat
        is identified and neutralized, no civilian traffic is permitted.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: I don't know what we're looking for. Command says it could come from
        any direction. We drew the short straw and got the road.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: Now step back.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags:
      - kick
