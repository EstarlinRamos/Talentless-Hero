  startNodeIndex: 0
  nodes:
  - editorLabel: Guard B - Casual
    lines:
    - speaker: Guard
      text: You're really going into the forest? On purpose?
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: Something's got the wildlife riled up. Started a few weeks ago. Nobody
        knows why.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: Our squad was sent here to investigate, but command split us up. Two
        here, two on the eastern road.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: We're supposed to be looking for something dangerous, but all we've found
        is angry slimes and confused wolves.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    - speaker: Guard
      text: Good luck out there. You'll probably need it.
      portraitOverride: {fileID: 0}
      emote: 
      sfx: {fileID: 0}
      sfxVolume: 1
      autoAdvanceDelay: 0
      tags: []
    choices: []
    nextNodeIndex: -1
